                { name: "Amaciante de roupas", category: "Limpeza" },
                { name: "Detergente líquido", category: "Limpeza" },
                { name: "Detergente para roupa", category: "Limpeza" },
                { name: "Lixívia (água sanitária)", category: "Limpeza" },
                { name: "Desinfetante", category: "Limpeza" },
                { name: "Esponja de louça", category: "Limpeza" },
                { name: "Lustra-móveis", category: "Limpeza" }
            ];

            // Remover duplicatas por nome
            const uniqueProducts = Array.from(new Map(products.map(p => [p.name.toLowerCase(), p])).values());
            uniqueProducts.sort((a, b) => a.name.localeCompare(b.name, 'pt'));

            // ---------- ESTADO ----------
            let shoppingList = [];
            let catalogView = 'category'; // 'category' ou 'alpha'

            // Carregar lista do localStorage (se houver)
            try {
                const saved = localStorage.getItem('shoppingList');
                if (saved) shoppingList = JSON.parse(saved);
            } catch (e) {}

            // ---------- FUNÇÕES DE PERSISTÊNCIA ----------
            function saveList() {
                localStorage.setItem('shoppingList', JSON.stringify(shoppingList));
            }

            // ---------- RENDER CATÁLOGO ----------
            function renderCatalog() {
                const container = document.getElementById('catalogContainer');
                if (!container) return;

                if (catalogView === 'category') {
                    const grouped = {};
                    uniqueProducts.forEach(p => {
                        const cat = p.category || 'Outros';
                        if (!grouped[cat]) grouped[cat] = [];
                        grouped[cat].push(p);
                    });
                    const sortedCats = Object.keys(grouped).sort((a, b) => a.localeCompare(b, 'pt'));
                    let html = '';
                    sortedCats.forEach(cat => {
                        html += `<div class="category-group">`;
                        html += `<div class="category-title">${cat}</div>`;
                        grouped[cat].sort((a, b) => a.name.localeCompare(b.name, 'pt')).forEach(prod => {
                            html += `<div class="item-row">
                                <span class="item-name">${prod.name}</span>
                                <button class="add-btn" data-product="${prod.name}">+</button>
                            </div>`;
                        });
                        html += `</div>`;
                    });
                    container.innerHTML = html;
                } else {
                    let html = `<div class="category-group"><div class="category-title">📌 todos os itens</div>`;
                    uniqueProducts.forEach(prod => {
                        html += `<div class="item-row">
                            <span class="item-name">${prod.name}</span>
                            <button class="add-btn" data-product="${prod.name}">+</button>
                        </div>`;
                    });
                    html += '</div>';
                    container.innerHTML = html;
                }

                // Eventos dos botões +
                document.querySelectorAll('.add-btn').forEach(btn => {
                    btn.addEventListener('click', (e) => {
                        e.stopPropagation();
                        const productName = btn.getAttribute('data-product');
                        addToShoppingList(productName);
                    });
                });
            }

            // ---------- ADICIONAR ITEM ----------
            function addToShoppingList(productName) {
                const newItem = {
                    id: Date.now() + Math.random() * 1000,
                    name: productName,
                    qty: 1,
                    price: 0.0,
                    checked: false
                };
                shoppingList.push(newItem);
                saveList();
                renderShoppingList();
            }

            // ---------- RENDER LISTA PESSOAL ----------
            function renderShoppingList() {
                const container = document.getElementById('shoppingListContainer');
                const totalSpan = document.getElementById('grandTotal');
                if (!container) return;

                if (shoppingList.length === 0) {
                    container.innerHTML = `<div style="text-align:center; color:var(--text-tertiary); padding:30px 10px;">🛒 toque em + para adicionar itens</div>`;
                    totalSpan.innerText = '0.00';
                    return;
                }

                let html = '';
                let grandTotal = 0;

                shoppingList.forEach(item => {
                    const lineTotal = (item.qty || 0) * (item.price || 0);
                    grandTotal += lineTotal;
                    const checkedClass = item.checked ? 'checked' : '';

                    html += `<div class="list-item" data-id="${item.id}">
                        <input type="checkbox" class="item-check" ${item.checked ? 'checked' : ''} data-id="${item.id}">
                        <span class="item-name-list ${checkedClass}">${item.name}</span>
                        <input type="number" min="1" value="${item.qty}" class="item-qty" data-id="${item.id}" step="1" inputmode="numeric">
                        <input type="number" min="0" value="${item.price.toFixed(2)}" class="item-price" data-id="${item.id}" step="0.01" inputmode="decimal">
                        <span class="item-total">${lineTotal.toFixed(2)}</span>
                        <button class="remove-item" data-id="${item.id}">✕</button>
                    </div>`;
                });

                container.innerHTML = html;
                totalSpan.innerText = grandTotal.toFixed(2);

                // Event listeners
                container.querySelectorAll('.item-check').forEach(cb => {
                    cb.addEventListener('change', function(e) {
                        const id = parseFloat(this.dataset.id);
                        const item = shoppingList.find(i => i.id === id);
                        if (item) {
                            item.checked = this.checked;
                            saveList();
                            renderShoppingList();
                        }
                    });
                });

                container.querySelectorAll('.item-qty').forEach(inp => {
                    inp.addEventListener('input', function(e) {
                        const id = parseFloat(this.dataset.id);
                        const item = shoppingList.find(i => i.id === id);
                        if (item) {
                            item.qty = Math.max(1, parseInt(this.value) || 1);
                            saveList();
                            renderShoppingList();
                        }
                    });
                });

                container.querySelectorAll('.item-price').forEach(inp => {
                    inp.addEventListener('input', function(e) {
                        const id = parseFloat(this.dataset.id);
                        const item = shoppingList.find(i => i.id === id);
                        if (item) {
                            item.price = parseFloat(this.value) || 0;
                            saveList();
                            renderShoppingList();
                        }
                    });
                });

                container.querySelectorAll('.remove-item').forEach(btn => {
                    btn.addEventListener('click', function(e) {
                        const id = parseFloat(this.dataset.id);
                        shoppingList = shoppingList.filter(i => i.id !== id);
                        saveList();
                        renderShoppingList();
                    });
                });
            }

            // ---------- ADICIONAR PERSONALIZADO ----------
            function addCustomItem() {
                const customName = prompt("Digite o nome do produto:", "");
                if (customName && customName.trim() !== '') {
                    addToShoppingList(customName.trim());
                }
            }

            // ---------- TEMA ----------
            const themeToggle = document.getElementById('themeToggle');
            // Verificar preferência salva
            if (localStorage.getItem('theme') === 'night') {
                document.body.classList.add('night');
                themeToggle.innerText = '☀️';
            } else {
                themeToggle.innerText = '🌙';
            }

            themeToggle.addEventListener('click', () => {
                document.body.classList.toggle('night');
                const isNight = document.body.classList.contains('night');
                themeToggle.innerText = isNight ? '☀️' : '🌙';
                localStorage.setItem('theme', isNight ? 'night' : 'day');
            });

            // ---------- INICIALIZAÇÃO ----------
            document.addEventListener('DOMContentLoaded', () => {
                renderCatalog();
                renderShoppingList();

                const btnCat = document.getElementById('viewCategory');
                const btnAlpha = document.getElementById('viewAlpha');

                btnCat.addEventListener('click', () => {
                    catalogView = 'category';
                    btnCat.classList.add('active');
                    btnAlpha.classList.remove('active');
                    renderCatalog();
                });

                btnAlpha.addEventListener('click', () => {
                    catalogView = 'alpha';
                    btnAlpha.classList.add('active');
                    btnCat.classList.remove('active');
                    renderCatalog();
                });

                document.getElementById('addCustomBtn').addEventListener('click', addCustomItem);
            });
        })();
        //]]>
    </script>
</body>
</html>
